{
  "name": "alboe",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/alboe-development/alboe.git"
  },
  "license": "MIT",
  "workspaces": [
    "modules/**/*"
  ],
  "scripts": {
    "@workspaces": "pnpm run -r",
    "@app": "pnpm @workspaces --filter @alboe/*-app",
    "@config": "pnpm @workspaces --filter @alboe/*-config",
    "clean": "pnpm clean:dependencies && pnpm clean:distribution",
    "clean:dependencies": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "clean:distribution": "find . -name 'dist' -type d -prune -exec rm -rf '{}' +"
  },
  "devDependencies": {
    "@alboe/eslint-config": "workspace:*",
    "eslint": "catalog:"
  }
}
